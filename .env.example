# ==================== 通用LLM配置(优先级最高) ====================
# 支持任何OpenAI兼容API(如智谱GLM、DeepSeek、月之暗面等)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_MODEL=glm-5.1

# ==================== OpenAI 配置 ====================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o-mini

# ==================== 百度文心一言配置 ====================
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_MODEL_NAME=ernie-3.5-8k

# ==================== 字节豆包配置 ====================
BYTEPLUS_API_KEY=
BYTEPLUS_MODEL_NAME=doubao-pro-32k
BYTEPLUS_ENDPOINT_ID=
BYTEPLUS_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ==================== CORS配置 ====================
CORS_ORIGINS=*

# ==================== 数据存储路径 ====================
DATA_DIR=./data

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
